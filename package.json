    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^24",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.0.3",
    "eslint-plugin-svelte": "^3.15.2",
    "globals": "^17.4.0",
    "svelte": "^5.54.0",
    "svelte-check": "^4.4.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1"
